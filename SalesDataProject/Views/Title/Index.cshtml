@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor
@{
    var canAccessTitle = ViewData["CanViewTitles"]?.ToString();
    var canDeleteTitle = ViewData["CanDeleteTitles"]?.ToString();
    ViewBag.CanAccessTitle = "True";
    ViewBag.CanDeleteTitle = "True";
    var isModified = ViewBag.IsModifiedUpload ?? false;
}

@model ValidationResultViewModel

<div class="container mt-5">
    <div class="header d-flex justify-content-between align-items-center p-4 bg-white shadow rounded mb-4" style="background: linear-gradient(156deg, #F8F9FA, #D6EAF8);">
        <h2 class="text m-0 text-left flex-grow-1 fw-bold"><i>Title Publication Validation</i></h2>

        @if (ViewData["CanViewTitles"]?.ToString() == "True")
        {
            <div class="d-flex gap-3">
                <form asp-action="ViewTitles" method="get">
                    <button type="submit" class="btn btn-warning fw-bold px-4 shadow-sm custom-hover-button" style="background-color: coral; color: white; border: none;">
                        <i class="bi bi-eye"></i> View Titles
                    </button>
                </form>
                <form asp-action="ModifiedTitles" method="get">
                    <button type="submit" class="btn btn-outline-primary fw-bold px-4 shadow-sm custom-hover-button" style="background-color: darkgrey; color: white; border: none;">
                        <i class="bi bi-eye"></i> Modified Title
                    </button>
                </form>
                <a href="@Url.Action("Index", "Home")">
                    <button type="button" class="btn fw-bold px-4 shadow-sm custom-hover-button" style="background-color: red; color: white;">
                        <i class="bi bi-arrow-left-circle"></i> Back
                    </button>
                </a>
            </div>
        }
    </div>

    <div class="card shadow rounded mb-4">
        <div class="card-body d-flex justify-content-between align-items-center">
            <h4 class="text-danger fw-bold"><i>Upload Titles Publication</i></h4>
            <div class="d-flex gap-2">
                <form asp-action="UploadExcel" method="post" enctype="multipart/form-data" id="uploadForm" class="d-flex gap-2">
                    <input type="file" id="fileUpload" name="file" class="d-none" required />
                    <input type="hidden" id="testMode" name="testMode" value="false" />

                    <button type="button" id="testUploadButton" class="btn btn-warning fw-semibold px-3 py-2 shadow-sm" style="background-color: #ff8c00; color: white;">
                        <i class="bi bi-check-circle me-1"></i> Test Upload
                    </button>

                    <button type="button" id="uploadAndSaveButton" class="btn btn-primary fw-semibold px-3 py-2 shadow-sm">
                        <i class="bi bi-upload me-1"></i> Upload & Save
                    </button>
                </form>
                <form>
                    <button type="submit" class="btn btn-success fw-semibold px-3 py-2 shadow-sm" id="downloadBtn">
                        <i class="bi bi-file-earmark-arrow-down me-1"></i> Download Template
                    </button>
                </form>
            </div>
        </div>
    </div>

@if (Model != null && (Model.BlockedTitles?.Any() == true || Model.CleanTitles?.Any() == true || Model.DuplicateTitlesInExcel?.Any() == true))
{
        <div class="card shadow rounded mb-4">
            <div class="card-body">

                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="card-title text-dark fw-bold m-0">
                        <i class="bi bi-check-circle"></i> Validation Result
                    </h5>
                </div>

                <div class="table-responsive" style="max-height: 600px; overflow-y: auto;">
                    <table class="table table-hover align-middle table-bordered">

                        <!-- HEADER -->
                        <thead class="table-dark text-center" style="position: sticky; top: 0; z-index: 1;">
                            <tr>
                                <th style="width: 90px;">Row No</th>
                                <th style="min-width: 150px;">Paper Id</th>

                                @if (!isModified)
                                {
                                    <th style="width: 140px;">Lot Number</th>
                                    <th style="width: 140px;">CodeRef</th>
                                    <th style="min-width: 350px; width: 25%;">Title</th>
                                    <th style="width: 130px;">FinancialYear</th>
                                    <th style="width: 130px;">BlockedByRow</th>
                                    <th style="width: 150px;">BlockInvoiceNo</th>
                                    <th style="width: 140px;">BlockCodeRef</th>
                                }

                                <th style="min-width: 400px; width: 30%;">Modified Title</th>
                                <th style="width: 120px;">Status</th>
                            </tr>
                        </thead>

                        <tbody>

                            <!-- CLEAN -->
                            @foreach (var title in Model.CleanTitles)
                            {
                                <tr class="table-success text-center">
                                    <td>@title.RowNumber</td>

                                    <td style="min-width: 150px; white-space: normal; word-break: break-word;">
                                        @title.PaperId
                                    </td>

                                    @if (!isModified)
                                    {
                                        <td>@title.InvoiceNumber</td>
                                        <td>@title.CodeReference</td>
                                        <td class="text-start" style="min-width: 350px; white-space: normal; word-break: break-word;">
                                            @title.Title
                                        </td>
                                        <td style="white-space: nowrap;">@(title.TitleYear ?? "-")</td>
                                        <td>-</td>
                                        <td>@(title.BlockedByInvoiceNo ?? "-")</td>
                                        <td>@(title.BlockedCodeRef ?? "-")</td>
                                    }

                                    <td class="text-start" style="min-width: 400px; white-space: normal; word-break: break-word;">
                                        @title.UpdatedTitle
                                    </td>
                                    <td>
                                        <span class="badge bg-success">
                                            @(isModified ? "PASS" : title.Status)
                                        </span>
                                    </td>
                                </tr>
                            }

                            <!-- BLOCKED -->
                            @foreach (var title in Model.BlockedTitles)
                            {
                                <tr class="table-warning text-center">
                                    <td>@title.RowNumber</td>

                                    <td style="min-width: 150px; white-space: normal; word-break: break-word;">
                                        @title.PaperId
                                    </td>

                                    @if (!isModified)
                                    {
                                        <td>@title.InvoiceNumber</td>
                                        <td>@title.CodeReference</td>
                                        <td class="text-start" style="min-width: 350px; white-space: normal; word-break: break-word;">
                                            @title.Title
                                        </td>
                                        <td style="white-space: nowrap;">@(title.TitleYear ?? "-")</td>
                                        <td>@title.BlockedId</td>
                                        <td>@(title.BlockedByInvoiceNo ?? "-")</td>
                                        <td>@(title.BlockedCodeRef ?? "-")</td>
                                    }

                                    <td class="text-start" style="min-width: 400px; white-space: normal; word-break: break-word;">
                                        @title.UpdatedTitle
                                    </td>
                                    <td>
                                        <span class="badge bg-warning text-dark">
                                            @(isModified ? "FAIL" : title.Status)
                                        </span>
                                    </td>
                                </tr>
                            }

                            <!-- DUPLICATE -->
                            @foreach (var title in Model.DuplicateTitlesInExcel)
                            {
                                <tr class="table-danger text-center">
                                    <td>@title.RowNumber</td>

                                    <td style="min-width: 150px; white-space: normal; word-break: break-word;">
                                        @title.PaperId
                                    </td>

                                    @if (!isModified)
                                    {
                                        <td>@title.InvoiceNumber</td>
                                        <td>@title.CodeReference</td>
                                        <td class="text-start" style="min-width: 350px; white-space: normal; word-break: break-word;">
                                            @title.Title
                                        </td>
                                        <td style="white-space: nowrap;">@(title.TitleYear ?? "-")</td>
                                        <td>@title.BlockedId</td>
                                        <td>@(title.BlockedByInvoiceNo ?? "-")</td>
                                        <td>@(title.BlockedCodeRef ?? "-")</td>
                                    }

                                    <td class="text-start" style="min-width: 400px; white-space: normal; word-break: break-word;">
                                        @title.UpdatedTitle
                                    </td>
                                    <td>
                                        <span class="badge bg-danger">
                                            @(isModified ? "FAIL" : title.Status)
                                        </span>
                                    </td>
                                </tr>
                            }

                        </tbody>
                    </table>
                </div>
            </div>
        </div>
}

<script>
    document.addEventListener('DOMContentLoaded', function () {
        const uploadAndSaveButton = document.getElementById('uploadAndSaveButton');
        const testUploadButton = document.getElementById('testUploadButton');
        const fileUpload = document.getElementById('fileUpload');
        const uploadForm = document.getElementById('uploadForm');
        const testModeInput = document.getElementById('testMode');

        if (uploadAndSaveButton && testUploadButton && fileUpload && uploadForm && testModeInput) {

            uploadAndSaveButton.addEventListener('click', function () {
                testModeInput.value = 'false'; // Set testMode = false for Upload and Save
                fileUpload.click();
            });

            testUploadButton.addEventListener('click', function () {
                testModeInput.value = 'true'; // Set testMode = true for Test Upload
                fileUpload.click();
            });

            fileUpload.addEventListener('change', function () {
                if (fileUpload.files.length > 0) {
                    showSpinner(); // Show loader
                    uploadForm.submit();
                }
            });
        }
    });

    function showSpinner() {
        document.getElementById("spinner-overlay").style.display = "flex";
    }

    function hideSpinner() {
        document.getElementById("spinner-overlay").style.display = "none";
    }

    window.addEventListener('load', function () {
        hideSpinner();
    });
</script>

<style>
