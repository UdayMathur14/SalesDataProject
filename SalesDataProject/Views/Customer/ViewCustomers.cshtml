@model IEnumerable<SalesDataProject.Models.Customer>
@{
    ViewData["Title"] = "Company Records";

    // Controller se bheja hua pagination data ViewBag se retrieve kar rahe hain
    int currentPage = ViewBag.CurrentPage ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
    int pageSize = ViewBag.PageSize ?? 10;
    int totalRecords = ViewBag.TotalRecords ?? 0;
}

<style>
    .table-header {
        background-color: darkslateblue;
        color: white;
    }
    /* Spinner styling tweaked for a better modern look */
    #spinner-overlay {
        display: none;
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.6);
        z-index: 9999;
        justify-content: center;
        align-items: center;
        flex-direction: column;
    }

    .spinner-box {
        background: #fff;
        padding: 20px 40px;
        border-radius: 8px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.2);
        text-align: center;
    }
</style>

<div class="container-fluid px-4 mt-4">
    <div class="header d-flex justify-content-between align-items-center flex-wrap gap-3">
        <h2><i>Company Records</i> <small class="text-muted" style="font-size: 14px;">(Total: @totalRecords)</small></h2>
        <div class="buttons d-flex gap-2 flex-wrap">
            <a href="@Url.Action("Index", "Customer")" class="btn btn-success">Create</a>
            <a href="@Url.Action("AllCustomers", "Customer")" class="btn btn-primary">Show All</a>

            <form asp-action="UploadExcel" asp-controller="Customer" method="post" enctype="multipart/form-data" id="uploadForm" style="display:inline;">
                @Html.AntiForgeryToken()
                <input type="file" id="fileUpload" name="file" accept=".xlsx, .xls" style="display:none;" />
                <button type="button" id="uploadButton" class="btn btn-success">Upload Excel</button>
            </form>

            <button type="button" id="downloadBtn" class="btn btn-success">Download Template</button>
            <a href="@Url.Action("Index", "Home")" class="btn btn-danger">Back</a>
        </div>
    </div>

    @if (totalPages > 1)
    {
        <div class="d-flex justify-content-between align-items-center bg-light p-2 border rounded-top border-bottom-0 mt-3">
            <div class="text-muted small">
                Showing @(((currentPage - 1) * pageSize) + 1) to @(Math.Min(currentPage * pageSize, totalRecords)) of @totalRecords entries
            </div>
            <div class="text-muted small">Page <strong>@currentPage</strong> of <strong>@totalPages</strong></div>
        </div>
    }

    <div class="table-responsive" style="max-height:600px; overflow-y:auto; border:1px solid #ddd; border-radius: @(totalPages > 1 ? "0 0 5px 5px" : "5px"); margin-top: @(totalPages > 1 ? "0px" : "15px");">
        <table class="table table-striped table-hover mb-0">
            <thead class="table-header sticky-top">
                <tr>
                    <th style="width:70px">#</th>
                    <th>Company Name</th>
                    <th>Email</th>
                    <th>Contact Number</th>
                    <th>Country</th>
                    <th>Contact Person</th>
                    <th>Category</th>
                    <th>Created By</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    // Serial number page number ke hisab se badlega (Page 2 par 11 se shuru hoga)
                    var serial = ((currentPage - 1) * pageSize) + 1;

                    foreach (var customer in Model)
                    {
                        <tr>
                            <td>@serial</td>
                            <td>@customer.COMPANY_NAME</td>
                            <td>@customer.CUSTOMER_EMAIL</td>
                            <td>@customer.CUSTOMER_CONTACT_NUMBER1</td>
                            <td>@customer.COUNTRY</td>
                            <td>@customer.CONTACT_PERSON</td>
                            <td>@(string.IsNullOrWhiteSpace(customer.CATEGORY) ? "-" : customer.CATEGORY)</td>
                            <td>@customer.CREATED_BY</td>
                        </tr>
                        serial++;
                    }
                }
                else
                {
                    <tr>
                        <td colspan="8" class="text-center text-muted py-4">No records found.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (totalPages > 1)
    {
        <div class="d-flex justify-content-end align-items-center mt-3 mb-4">
            <nav aria-label="Page navigation">
                <ul class="pagination pagination-sm mb-0">
                    <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                        <a class="page-link" href="@Url.Action("ViewCustomers", new { pageNumber = 1, pageSize = pageSize })">First</a>
                    </li>
                    <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                        <a class="page-link" href="@Url.Action("ViewCustomers", new { pageNumber = currentPage - 1, pageSize = pageSize })">Previous</a>
                    </li>

                    @{
                        int startPage = Math.Max(1, currentPage - 2);
                        int endPage = Math.Min(totalPages, startPage + 4);
                        if (endPage - startPage < 4)
                        {
                            startPage = Math.Max(1, endPage - 4);
                        }
                    }

                    @for (int i = startPage; i <= endPage; i++)
                    {
                        if (i >= 1 && i <= totalPages)
                        {
                            <li class="page-item @(currentPage == i ? "active" : "")">
                                <a class="page-link" href="@Url.Action("ViewCustomers", new { pageNumber = i, pageSize = pageSize })">@i</a>
                            </li>
                        }
                    }

                    <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                        <a class="page-link" href="@Url.Action("ViewCustomers", new { pageNumber = currentPage + 1, pageSize = pageSize })">Next</a>
                    </li>
                    <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                        <a class="page-link" href="@Url.Action("ViewCustomers", new { pageNumber = totalPages, pageSize = pageSize })">Last</a>
                    </li>
                </ul>
            </nav>
        </div>
    }
</div>

<div id="spinner-overlay">
    <div class="spinner-box">
        <div class="spinner-border text-primary mb-2" role="status"></div>
        <div class="text-dark fw-bold">Processing... Please wait</div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const uploadButton = document.getElementById('uploadButton');
            const fileUpload = document.getElementById('fileUpload');
            const uploadForm = document.getElementById('uploadForm');
            const downloadBtn = document.getElementById('downloadBtn');
            const spinner = document.getElementById('spinner-overlay');

            function showSpinner() {
                spinner.style.display = "flex";
            }
            function hideSpinner() {
                spinner.style.display = "none";
            }

            // Spinner loader overlay attach karega saare page number links par clicks ke waqt
            document.querySelectorAll('.pagination a').forEach(link => {
                link.addEventListener('click', function() {
                    if(!this.parentElement.classList.contains('disabled') && !this.parentElement.classList.contains('active')) {
                        showSpinner();
                    }
                });
            });

            // Excel upload trigger
            if (uploadButton && fileUpload && uploadForm) {
                uploadButton.addEventListener('click', function () {
                    fileUpload.click();
                });

                fileUpload.addEventListener('change', function () {
                    if (fileUpload.files.length > 0) {
                        showSpinner();
                        uploadForm.submit();
                    }
                });
            }

            // Template download using Fetch Blob API safely
            if (downloadBtn) {
                downloadBtn.addEventListener('click', function (event) {
                    event.preventDefault();
                    showSpinner();

                    fetch('/Customer/DownloadTemplate', { method: 'GET' })
                        .then(response => {
                            if (!response.ok) throw new Error("Server error " + response.status);
                            return response.blob();
                        })
                        .then(blob => {
                            hideSpinner();
                            const link = document.createElement("a");
                            link.href = window.URL.createObjectURL(blob);
                            link.download = "CustomerTemplate.xlsx";
                            document.body.appendChild(link);
                            link.click();
                            document.body.removeChild(link);
                        })
                        .catch(err => {
                            hideSpinner();
                            alert("Download failed: " + err.message);
                        });
                });
            }

            // Safeguard: Ensure spinner hides if user navigates back to cached page
            window.addEventListener('pageshow', function (event) {
                if (event.persisted) {
                    hideSpinner();
                }
            });
        });
    </script>
}