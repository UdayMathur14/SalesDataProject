@model SalesDataProject.Models.Customer
@{
    ViewData["Title"] = "Create Customer";
}

<div class="container mt-4">
    <h2 class="mb-4 text-center">Create Customer</h2>

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <form asp-action="Create" method="post" enctype="multipart/form-data">
                <div class="form-row mb-2 d-flex gap-4">
                    <div class="col-md-3">
                        <label asp-for="CUSTOMER_CODE" class="font-weight-bold">Customer Code</label>
                        <input asp-for="CUSTOMER_CODE" class="form-control form-control-sm" />
                        <span asp-validation-for="CUSTOMER_CODE" class="text-danger"></span>
                    </div>
                    <div class="col-md-3">
                        <label asp-for="COMPANY_NAME" class="font-weight-bold">Company Name <span class="text-danger">*</span></label>
                        <input asp-for="COMPANY_NAME" class="form-control form-control-sm" />
                        <span asp-validation-for="COMPANY_NAME" class="text-danger"></span>
                    </div>
                    <div class="col-md-3">
                        <label asp-for="CONTACT_PERSON" class="font-weight-bold">Contact Person <span class="text-danger">*</span></label>
                        <input asp-for="CONTACT_PERSON" class="form-control form-control-sm" />
                        <span asp-validation-for="CONTACT_PERSON" class="text-danger"></span>
                    </div>
                </div>

                <div class="form-row mb-2 d-flex gap-4">
                    <div class="col-md-3">
                        <label asp-for="COUNTRY_CODE" class="font-weight-bold">Country Code <span class="text-danger">*</span></label>
                        <select asp-for="COUNTRY_CODE" class="form-control form-control-sm" id="CountryCode">
                            <option disabled value="">-- Select Code --</option>
                            @foreach (var code in ViewBag.CountryCodes as SelectList)
                            {
                                <option value="@code.Text">@code.Text</option>
                            }
                        </select>
                        <span asp-validation-for="COUNTRY_CODE" class="text-danger"></span>
                    </div>
                    <div class="col-md-3">
                        <label asp-for="CUSTOMER_CONTACT_NUMBER1" class="font-weight-bold">Contact Number1 <span class="text-danger">*</span></label>
                        <input asp-for="CUSTOMER_CONTACT_NUMBER1" class="form-control form-control-sm" />
                        <span asp-validation-for="CUSTOMER_CONTACT_NUMBER1" class="text-danger"></span>
                    </div>
                    <div class="col-md-3">
                        <label asp-for="CUSTOMER_CONTACT_NUMBER2" class="font-weight-bold">Contact Number2</label>
                        <input asp-for="CUSTOMER_CONTACT_NUMBER2" class="form-control form-control-sm" />
                        <span asp-validation-for="CUSTOMER_CONTACT_NUMBER2" class="text-danger"></span>
                    </div>
                </div>

                <div class="form-row mb-2 d-flex gap-4">
                    <div class="col-md-3">
                        <label asp-for="CUSTOMER_CONTACT_NUMBER3" class="font-weight-bold">Contact Number3</label>
                        <input asp-for="CUSTOMER_CONTACT_NUMBER3" class="form-control form-control-sm" />
                        <span asp-validation-for="CUSTOMER_CONTACT_NUMBER3" class="text-danger"></span>
                    </div>
                    <div class="col-md-3">
                        <label asp-for="CUSTOMER_EMAIL" class="font-weight-bold">Email <span class="text-danger">*</span></label>
                        <input asp-for="CUSTOMER_EMAIL" class="form-control form-control-sm" />
                        <span asp-validation-for="CUSTOMER_EMAIL" class="text-danger"></span>
                    </div>
                    <div class="col-md-3">
                        <label asp-for="COUNTRY" class="font-weight-bold">Country <span class="text-danger">*</span></label>
                        <select asp-for="COUNTRY" class="form-control form-control-sm">
                            <option disabled value="">-- Select Country --</option>
                            @foreach (var country in ViewBag.Countries as SelectList)
                            {
                                <option value="@country.Text">@country.Text</option>
                            }
                        </select>
                        <span asp-validation-for="COUNTRY" class="text-danger"></span>
                    </div>
                </div>

                <div class="form-row mb-2 d-flex gap-4">
                    <div class="col-md-3">
                        <label asp-for="STATE" class="font-weight-bold">State</label>
                        <input asp-for="STATE" class="form-control form-control-sm" />
                        <span asp-validation-for="STATE" class="text-danger"></span>
                    </div>
                    <div class="col-md-3">
                        <label asp-for="CITY" class="font-weight-bold">City</label>
                        <input asp-for="CITY" class="form-control form-control-sm" />
                        <span asp-validation-for="CITY" class="text-danger"></span>
                    </div>
                    <div class="col-md-3">
                        <label asp-for="CATEGORY" class="font-weight-bold">Category</label>
                        <select asp-for="CATEGORY" class="form-control form-control-sm">
                            <option value="" selected>--Select Category--</option>
                            <option value="UNIVERSITY">University</option>
                            <option value="MSME">MSME</option>
                            <option value="CORPORATE">Corporate</option>
                            <option value="LAWFIRM">Law Firm</option>
                            <option value="PCT">PCT</option>
                            <option value="INDIVIDUAL">Individual</option>
                        </select>
                    </div>
                </div>

                <div class="form-row col-md-3 d-flex align-items-end gap-4 mt-3">
                    <button type="submit" class="btn btn-primary">Submit</button>
                    <button type="button" class="btn btn-danger" onclick="window.location.href='@Url.Action("ViewCustomers", "Customer")'">Back</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}