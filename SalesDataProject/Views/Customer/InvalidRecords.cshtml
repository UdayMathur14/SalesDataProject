@model IEnumerable<SalesDataProject.Models.InvalidCustomerRecord>
@{
    ViewData["Title"] = "Invalid Records";
    var hasRecords = Model != null && Model.Any();
}

<div class="container">
    <div class="header d-flex justify-content-between mb-4">
        <h2>Invalid or Duplicate Records</h2>
        <div class="buttons d-flex gap-2">
            @if (hasRecords)
            {
                <a asp-action="ExportInvalidRecords" class="btn btn-primary">Export to Excel</a>
            }
            else
            {
                <a class="btn btn-primary disabled" aria-disabled="true">Export to Excel</a>
            }
            <a href="@Url.Action("Index", "Customer")" class="btn btn-danger">Back</a>
        </div>
    </div>

    @if (!hasRecords)
    {
        <p>No invalid or duplicate records found.</p>
    }
    else
    {
        <div style="max-height:800px; overflow-y:auto; border:1px solid #ddd; border-radius:5px;">
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>Excel Row</th>
                        <th>Company Name</th>
                        <th>Customer Email</th>
                        <th>Customer Number</th>
                        <th>Error</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var record in Model)
                    {
                        <tr>
                            <td>@record.RowNumber</td>
                            <td>@record.CompanyName</td>
                            <td>@record.CustomerEmail</td>
                            <td>@record.CustomerNumber</td>
                            <td class="text-danger fw-semibold">@record.ErrorMessage</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>